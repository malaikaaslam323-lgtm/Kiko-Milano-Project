<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Checkout - KIKO MILANO</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/first.css">
    <link rel="stylesheet" href="/ecommerce.css">
</head>
<body>

    <!-- Header Partial -->
    <%- include('partials/header') %>

    <div class="checkout-wrapper">
        <h1 class="cart-title" style="margin-bottom: 40px;">SECURE CHECKOUT</h1>

        <!-- Alert messages -->
        <div style="max-width: 1200px; margin: 0 auto;">
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="flash-msg flash-error"><%= error_msg %></div>
            <% } %>
        </div>

        <div class="checkout-layout">
            <!-- Left: Shipping & Payment Details -->
            <div class="checkout-form-section">
                <form action="/checkout/submit" method="POST" id="checkout-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    
                    <div class="checkout-section-title">DELIVERY INFORMATION</div>
                    
                    <div class="form-group-spaced">
                        <label class="kiko-label">Full Recipient Name *</label>
                        <input type="text" name="name" class="kiko-input" required placeholder="e.g. Malaika Aslam">
                    </div>

                    <div class="form-group-spaced">
                        <label class="kiko-label">Street Address *</label>
                        <input type="text" name="address" class="kiko-input" required placeholder="e.g. House 42, Sector F-6">
                    </div>

                    <div style="display: flex; gap: 20px;">
                        <div class="form-group-spaced" style="flex: 1.5; margin-bottom: 0;">
                            <label class="kiko-label">City *</label>
                            <input type="text" name="city" class="kiko-input" required placeholder="e.g. Islamabad">
                        </div>

                        <div class="form-group-spaced" style="flex: 1; margin-bottom: 0;">
                            <label class="kiko-label">Postal Code *</label>
                            <input type="text" name="postalCode" class="kiko-input" required placeholder="e.g. 44000">
                        </div>
                    </div>

                    <div class="form-group-spaced" style="margin-top: 24px;">
                        <label class="kiko-label">Phone Number *</label>
                        <input type="tel" name="phone" class="kiko-input" required placeholder="e.g. +92 300 1234567">
                    </div>

                    <div class="checkout-section-title" style="margin-top: 40px;">PAYMENT METHOD</div>
                    
                    <div class="payment-options">
                        <label class="payment-option-label active" id="cod-label">
                            <input type="radio" name="paymentMethod" value="cod" checked style="accent-color: #ff1493;">
                            <span>CASH ON DELIVERY (COD)</span>
                        </label>
                        <label class="payment-option-label" id="card-label">
                            <input type="radio" name="paymentMethod" value="card" style="accent-color: #ff1493;">
                            <span>CREDIT / DEBIT CARD</span>
                        </label>
                    </div>

                    <!-- Card details section (only displays if Card payment selected) -->
                    <div id="card-details-section" style="display: none;">
                        <% if (stripePublishableKey) { %>
                            <div class="stripe-card-element-wrapper">
                                <label class="kiko-legend" style="margin-bottom: 10px; display: block;">Credit or Debit Card</label>
                                <div id="card-element"></div>
                                <div id="card-errors" class="card-errors" role="alert"></div>
                            </div>
                            <input type="hidden" name="stripeToken" id="stripeToken">
                        <% } else { %>
                            <!-- High-Fidelity Simulation card details input -->
                            <div style="border: 1px solid #ddd; border-radius: 6px; padding: 20px; background-color: #fafafa; margin-bottom: 25px;">
                                <div style="font-size: 11px; font-weight: 700; color: #ff1493; letter-spacing: 1px; margin-bottom: 15px;">STRIPE SIMULATION ACTIVE</div>
                                
                                <div class="form-group-spaced" style="margin-bottom: 15px;">
                                    <label class="kiko-label">Card Number *</label>
                                    <input type="text" placeholder="4242 4242 4242 4242" class="kiko-input" style="letter-spacing: 2px;">
                                </div>
                                
                                <div style="display: flex; gap: 15px;">
                                    <div class="form-group-spaced" style="flex: 1.5; margin-bottom: 0;">
                                        <label class="kiko-label">Expiry Date *</label>
                                        <input type="text" placeholder="MM/YY" class="kiko-input">
                                    </div>
                                    <div class="form-group-spaced" style="flex: 1; margin-bottom: 0;">
                                        <label class="kiko-label">CVC *</label>
                                        <input type="text" placeholder="123" class="kiko-input">
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <button type="submit" class="kiko-btn" id="submit-order-btn" style="margin-top: 20px;">PLACE ORDER</button>
                </form>
            </div>

            <!-- Right: Summary -->
            <div class="cart-summary-section" style="flex: 1; border-color: #eee;">
                <h2 class="summary-title">Order Summary</h2>
                
                <div style="max-height: 250px; overflow-y: auto; margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <% cartItems.forEach(item => { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; font-size: 13px;">
                            <div style="display: flex; align-items: center; gap: 12px; max-width: 75%;">
                                <img src="/<%= item.product.image %>" style="width: 45px; height: 45px; object-fit: contain; background: #fafafa; border-radius: 4px; border: 1px solid #eee;">
                                <div>
                                    <div style="font-weight: 700; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px;"><%= item.product.name %></div>
                                    <div style="color: #666; font-size: 11px; margin-top: 2px;">Qty: <%= item.quantity %></div>
                                </div>
                            </div>
                            <span style="font-weight: 600;">PKR <%= (item.product.price * item.quantity).toLocaleString() %></span>
                        </div>
                    <% }) %>
                </div>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>PKR <%= subtotal.toLocaleString() %></span>
                </div>
                
                <div class="summary-row">
                    <span>Shipping</span>
                    <% if (shipping === 0) { %>
                        <span style="color: #ff1493; font-weight: 700;">FREE</span>
                    <% } else { %>
                        <span>PKR <%= shipping.toLocaleString() %></span>
                    <% } %>
                </div>

                <div class="summary-row total-row">
                    <span>Total Amount</span>
                    <span>PKR <%= total.toLocaleString() %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Partial -->
    <%- include('partials/footer') %>

    <!-- Checkout Dynamic JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const codLabel = document.getElementById('cod-label');
            const cardLabel = document.getElementById('card-label');
            const cardDetailsSection = document.getElementById('card-details-section');
            const checkoutForm = document.getElementById('checkout-form');
            const submitBtn = document.getElementById('submit-order-btn');

            // Handle payment option styling and section toggling
            document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if (e.target.value === 'card') {
                        cardLabel.classList.add('active');
                        codLabel.classList.remove('active');
                        cardDetailsSection.style.display = 'block';
                    } else {
                        codLabel.classList.add('active');
                        cardLabel.classList.remove('active');
                        cardDetailsSection.style.display = 'none';
                    }
                });
            });

            // Initialize Stripe if publishable key is present
            <% if (stripePublishableKey) { %>
                const stripe = Stripe('<%= stripePublishableKey %>');
                const elements = stripe.elements();

                const style = {
                    base: {
                        color: '#111111',
                        fontFamily: '"Montserrat", Helvetica, sans-serif',
                        fontSmoothing: 'antialiased',
                        fontSize: '15px',
                        '::placeholder': {
                            color: '#aab7c4'
                        }
                    },
                    invalid: {
                        color: '#ff0055',
                        iconColor: '#ff0055'
                    }
                };

                const card = elements.create('card', { style: style });
                card.mount('#card-element');

                card.on('change', (event) => {
                    const displayError = document.getElementById('card-errors');
                    if (event.error) {
                        displayError.textContent = event.error.message;
                    } else {
                        displayError.textContent = '';
                    }
                });

                // Intercept submission to tokenize card
                checkoutForm.addEventListener('submit', async (e) => {
                    const activePayment = document.querySelector('input[name="paymentMethod"]:checked').value;
                    if (activePayment !== 'card') return; // Let Cash on Delivery pass straight to backend

                    e.preventDefault();
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'AUTHORIZING PAYMENT...';

                    const { token, error } = await stripe.createToken(card);
                    if (error) {
                        const errorElement = document.getElementById('card-errors');
                        errorElement.textContent = error.message;
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'PLACE ORDER';
                    } else {
                        document.getElementById('stripeToken').value = token.id;
                        checkoutForm.submit(); // Submit tokenized payload
                    }
                });
            <% } else { %>
                // Mock simulation handling
                checkoutForm.addEventListener('submit', (e) => {
                    const activePayment = document.querySelector('input[name="paymentMethod"]:checked').value;
                    if (activePayment === 'card') {
                        submitBtn.disabled = true;
                        submitBtn.textContent = 'SIMULATING TRANSACTION...';
                    }
                });
            <% } %>
        });
    </script>

</body>
</html>
