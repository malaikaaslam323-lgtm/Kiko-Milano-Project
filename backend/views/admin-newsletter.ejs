<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Newsletter & Campaigns - KIKO MILANO</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin.css">
</head>
<body>

    <div class="admin-top-bar">
        <span>KIKO MILANO BACK OFFICE &bull; CENTRAL CONTROL PANEL</span>
    </div>

    <header class="admin-site-header">
        <div class="header-container">
            <div class="header-side-left">
                <span class="admin-badge-indicator">SYSTEM ADMIN</span>
            </div>
            
            <div class="admin-logo">
                <img src="/Logo.webp" alt="KIKO Milano">
            </div>

            <div class="header-side-right">
                <a href="/admin" class="return-store-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    BACK TO DASHBOARD
                </a>
            </div>
        </div>
    </header>

    <div class="dashboard-action-bar">
        <div class="title-block">
            <h1>NEWSLETTER SYSTEM</h1>
            <p>MANAGE SUBSCRIBERS & PROMOTIONAL CAMPAIGNS</p>
        </div>
    </div>

    <!-- Sub-Navigation Navigation Bar -->
    <div style="max-width: 1400px; margin: 10px auto 30px auto; padding: 0 50px; overflow-x: auto;">
        <div style="display: flex; gap: 10px; border-bottom: 2px solid #eaeaea; padding-bottom: 15px; min-width: max-content;">
            <a href="/admin" class="admin-nav-btn">PRODUCTS INVENTORY</a>
            <a href="/admin/orders" class="admin-nav-btn">ORDER MANAGEMENT</a>
            <a href="/admin/users" class="admin-nav-btn">REGISTERED CUSTOMERS</a>
            <a href="/admin/newsletter" class="admin-nav-btn" style="background-color: #000; color: #fff;">NEWSLETTER & CAMPAIGNS</a>
            <a href="/admin/reviews" class="admin-nav-btn">PRODUCT REVIEWS</a>
            <a href="/admin/sales" class="admin-nav-btn">LIVE SALES METRICS</a>
        </div>
    </div>

    <div style="max-width: 1400px; margin: 0 auto 10px auto; padding: 0 50px;">
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success" style="margin: 0 0 25px 0;"><%= success_msg %></div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error" style="background-color: #ffe6e6; color: #cc0000; padding: 15px; text-align: center; margin-bottom: 25px; border-radius: 4px; font-weight: 600; margin: 0 0 25px 0;"><%= error_msg %></div>
        <% } %>
    </div>

    <div style="max-width: 1400px; margin: 0 auto 40px auto; padding: 0 50px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        
        <!-- Left Column: Subscriber List & Search -->
        <div>
            <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;">SUBSCRIBER REGISTRY</h3>
            
            <div style="background: #fff; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); padding: 25px; margin-bottom: 25px;">
                <input type="text" id="subscriber-search" placeholder="🔍 Search subscriber emails..." style="width: 100%; padding: 12px 16px; border: 1px solid #ddd; border-radius: 4px; font-family: inherit; font-size: 14px; outline: none; margin-bottom: 20px; box-sizing: border-box;">
                
                <div style="max-height: 400px; overflow-y: auto;">
                    <% if (subscribers.length === 0) { %>
                        <p style="color: #888; font-size: 13px; text-align: center;">No email subscribers recorded yet.</p>
                    <% } else { %>
                        <table class="admin-table" style="box-shadow: none; border-radius: 0;">
                            <thead>
                                <tr>
                                    <th style="padding: 10px 15px; border-bottom: 2px solid #eee; background: none;">Email Address</th>
                                    <th style="padding: 10px 15px; border-bottom: 2px solid #eee; background: none; text-align: right;">Joined Date</th>
                                </tr>
                            </thead>
                            <tbody id="subscribers-tbody">
                                <% subscribers.forEach(sub => { %>
                                    <tr class="sub-row">
                                        <td class="sub-email" style="font-weight: 600; padding: 12px 15px;"><%= sub.email %></td>
                                        <td style="color: #666; font-size: 12px; padding: 12px 15px; text-align: right;">
                                            <%= new Date(sub.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Right Column: Campaign Composer & Logs -->
        <div>
            <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;">COMPOSE PROMOTIONAL CAMPAIGN</h3>
            
            <div style="background: #fff; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); padding: 35px; margin-bottom: 30px;">
                <form action="/admin/newsletter/send-campaign" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group">
                        <label>Campaign Title *</label>
                        <input type="text" name="title" placeholder="e.g. Eid Mubarak Sale - 20% Off All Makeup!" required>
                    </div>

                    <div class="form-group">
                        <label>Campaign Body (HTML or Plain Text) *</label>
                        <textarea name="body" rows="6" placeholder="Write your newsletter contents here..." required style="width: 100%; border: 1px solid #dddddd; border-radius: 4px; padding: 14px; font-family: inherit; font-size: 14px; resize: vertical; box-sizing: border-box; background: #fafafa;"></textarea>
                    </div>

                    <button type="submit" class="btn-submit" style="margin-top: 10px;">DISPATCH CAMPAIGN TO ALL SUBSCRIBERS</button>
                </form>
            </div>

            <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;">CAMPAIGN DISPATCH LOG</h3>
            <div style="background: #fff; padding: 25px; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); max-height: 400px; overflow-y: auto;">
                <% if (campaigns.length === 0) { %>
                    <p style="color: #888; font-size: 13px; text-align: center;">No campaigns have been sent yet.</p>
                <% } else { %>
                    <div style="display: flex; flex-direction: column; gap: 15px;">
                        <% campaigns.forEach(camp => { %>
                            <div style="border-bottom: 1px solid #f2f2f2; padding-bottom: 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px;">
                                    <h4 style="font-size: 13px; font-weight: 700; color: #111; margin: 0;"><%= camp.title %></h4>
                                    <span style="font-size: 9px; font-weight: 700; background: #e8f5e9; color: #2e7d32; padding: 3px 8px; border-radius: 20px; text-transform: uppercase;"><%= camp.status %></span>
                                </div>
                                <div style="font-size: 11px; color: #666; display: flex; justify-content: space-between; margin-top: 4px;">
                                    <span>Sent to: <strong><%= camp.sentCount %> subscribers</strong></span>
                                    <span>Date: <%= new Date(camp.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

    </div>

    <!-- Client-Side Search Script -->
    <script>
        document.getElementById('subscriber-search').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.sub-row');
            
            rows.forEach(row => {
                const email = row.querySelector('.sub-email').textContent.toLowerCase();
                if (email.includes(query)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>

</body>
</html>
