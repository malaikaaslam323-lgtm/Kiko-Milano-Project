<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Order Management - KIKO MILANO</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin.css">
    <link rel="stylesheet" href="/ecommerce.css">
</head>
<body>

    <div class="admin-top-bar">
        <span>KIKO MILANO BACK OFFICE &bull; CENTRAL CONTROL PANEL</span>
    </div>

    <header class="admin-site-header">
        <div class="header-container">
            <div class="header-side-left">
                <span class="admin-badge-indicator">SYSTEM ADMIN</span>
            </div>
            
            <div class="admin-logo">
                <img src="/Logo.webp" alt="KIKO Milano">
            </div>

            <div class="header-side-right">
                <a href="/admin" class="return-store-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    BACK TO DASHBOARD
                </a>
            </div>
        </div>
    </header>

    <div class="dashboard-action-bar">
        <div class="title-block">
            <h1>ORDER MANAGEMENT</h1>
            <p>REVIEW TRANSACTIONS & UPDATE DELIVERY STATUS</p>
        </div>
    </div>

    <!-- Sub-Navigation Navigation Bar -->
    <div style="max-width: 1400px; margin: 10px auto 30px auto; padding: 0 50px; overflow-x: auto;">
        <div style="display: flex; gap: 10px; border-bottom: 2px solid #eaeaea; padding-bottom: 15px; min-width: max-content;">
            <a href="/admin" class="admin-nav-btn">PRODUCTS INVENTORY</a>
            <a href="/admin/orders" class="admin-nav-btn" style="background-color: #000; color: #fff;">ORDER MANAGEMENT</a>
            <a href="/admin/users" class="admin-nav-btn">REGISTERED CUSTOMERS</a>
            <a href="/admin/newsletter" class="admin-nav-btn">NEWSLETTER & CAMPAIGNS</a>
            <a href="/admin/reviews" class="admin-nav-btn">PRODUCT REVIEWS</a>
            <a href="/admin/sales" class="admin-nav-btn">LIVE SALES METRICS</a>
        </div>
    </div>

    <div style="max-width: 1400px; margin: 0 auto 10px auto; padding: 0 50px;">
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success" style="margin: 0 0 25px 0;"><%= success_msg %></div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error" style="background-color: #ffe6e6; color: #cc0000; padding: 15px; text-align: center; margin-bottom: 25px; border-radius: 4px; font-weight: 600; margin: 0 0 25px 0;"><%= error_msg %></div>
        <% } %>
    </div>

    <!-- Orders Management List Table -->
    <div class="table-container">
        <% if (orders.length === 0) { %>
            <div style="background: #fff; padding: 50px; text-align: center; border-radius: 8px; border: 1px solid #eaeaea; color: #666; font-size: 14px;">
                No orders have been recorded in the database yet.
            </div>
        <% } else { %>
            <div style="background: #fff; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); overflow: hidden;">
                <table class="admin-table" style="box-shadow: none; border-radius: 0;">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer Info</th>
                            <th>Recipient & Phone</th>
                            <th>Total Amount</th>
                            <th>Payment</th>
                            <th>Date & Time</th>
                            <th>Items Summary</th>
                            <th>Delivery Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td style="font-weight: 700; font-family: monospace; font-size: 14px; color: #111;">
                                    #<%= order._id.toString().substring(0, 8).toUpperCase() %>
                                </td>
                                <td>
                                    <div style="font-weight: 600;"><%= order.customer ? order.customer.name : 'Guest User' %></div>
                                    <div style="font-size: 11px; color: #666;"><%= order.customer ? order.customer.email : 'N/A' %></div>
                                </td>
                                <td>
                                    <div style="font-weight: 600;"><%= order.recipientName || 'N/A' %></div>
                                    <div style="font-size: 11px; color: #666;"><%= order.phone || 'N/A' %></div>
                                </td>
                                <td style="font-weight: 700; color: #222;">
                                    PKR <%= order.totalAmount.toLocaleString() %>
                                </td>
                                <td>
                                    <span style="font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; background: #e0f2f1; color: #00796b; padding: 4px 10px; border-radius: 50px;">
                                        <%= order.paymentMethod || 'COD' %>
                                    </span>
                                </td>
                                <td style="color: #666; font-size: 12px;">
                                    <%= new Date(order.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                </td>
                                <td>
                                    <div style="display: flex; flex-direction: column; gap: 4px; font-size: 11px;">
                                        <% order.items.forEach(item => { %>
                                            <div>
                                                <%= item.product ? item.product.name : 'Unknown Product' %> 
                                                <strong style="color: #ff1493;">x<%= item.quantity %></strong>
                                            </div>
                                        <% }) %>
                                    </div>
                                </td>
                                <td>
                                    <form action="/admin/orders/update-status/<%= order._id %>" method="POST" style="display: flex; align-items: center; gap: 8px; margin: 0;">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <select name="status" style="padding: 6px 12px; font-family: inherit; font-size: 12px; font-weight: 600; border-radius: 4px; border: 1px solid #ddd; background: #fafafa; outline: none; margin: 0;" onchange="this.form.submit()">
                                            <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="Processing" <%= order.status === 'Processing' ? 'selected' : '' %>>Processing</option>
                                            <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                                            <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                                        </select>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

</body>
</html>
