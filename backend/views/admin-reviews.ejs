<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Reviews Management - KIKO MILANO</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin.css">
</head>
<body>

    <div class="admin-top-bar">
        <span>KIKO MILANO BACK OFFICE &bull; CENTRAL CONTROL PANEL</span>
    </div>

    <header class="admin-site-header">
        <div class="header-container">
            <div class="header-side-left">
                <span class="admin-badge-indicator">SYSTEM ADMIN</span>
            </div>
            
            <div class="admin-logo">
                <img src="/Logo.webp" alt="KIKO Milano">
            </div>

            <div class="header-side-right">
                <a href="/admin" class="return-store-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    BACK TO DASHBOARD
                </a>
            </div>
        </div>
    </header>

    <div class="dashboard-action-bar">
        <div class="title-block">
            <h1>PRODUCT REVIEWS</h1>
            <p>MODERATE CUSTOMER RATINGS & PLATFORM FEEDBACK</p>
        </div>
    </div>

    <!-- Sub-Navigation Navigation Bar -->
    <div style="max-width: 1400px; margin: 10px auto 30px auto; padding: 0 50px; overflow-x: auto;">
        <div style="display: flex; gap: 10px; border-bottom: 2px solid #eaeaea; padding-bottom: 15px; min-width: max-content;">
            <a href="/admin" class="admin-nav-btn">PRODUCTS INVENTORY</a>
            <a href="/admin/orders" class="admin-nav-btn">ORDER MANAGEMENT</a>
            <a href="/admin/users" class="admin-nav-btn">REGISTERED CUSTOMERS</a>
            <a href="/admin/newsletter" class="admin-nav-btn">NEWSLETTER & CAMPAIGNS</a>
            <a href="/admin/reviews" class="admin-nav-btn" style="background-color: #000; color: #fff;">PRODUCT REVIEWS</a>
            <a href="/admin/sales" class="admin-nav-btn">LIVE SALES METRICS</a>
        </div>
    </div>

    <div style="max-width: 1400px; margin: 0 auto 10px auto; padding: 0 50px;">
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success" style="margin: 0 0 25px 0;"><%= success_msg %></div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error" style="background-color: #ffe6e6; color: #cc0000; padding: 15px; text-align: center; margin-bottom: 25px; border-radius: 4px; font-weight: 600; margin: 0 0 25px 0;"><%= error_msg %></div>
        <% } %>
    </div>

    <!-- High-End Stats Grid -->
    <div class="stats-grid" style="max-width: 1400px; margin: 0 auto 30px auto; padding: 0 50px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="stat-card" style="background: #fff; padding: 25px; border-radius: 8px; border: 1px solid #eaeaea;">
            <h3><%= totalReviews %></h3>
            <p>Total Reviews Submitted</p>
        </div>
        <div class="stat-card" style="background: #fff; padding: 25px; border-radius: 8px; border: 1px solid #eaeaea;">
            <h3><%= averageRating %> ★</h3>
            <p>Average Platform Product Rating</p>
        </div>
    </div>

    <!-- Reviews Grid Layout -->
    <div style="max-width: 1400px; margin: 0 auto 40px auto; padding: 0 50px; display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 30px; align-items: start;">
        
        <!-- Left: Reviews moderating table -->
        <div>
            <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;">REVIEWS REGISTRY</h3>
            
            <div style="background: #fff; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); overflow: hidden;">
                <% if (reviews.length === 0) { %>
                    <div style="padding: 50px; text-align: center; color: #888; font-size: 14px;">No product reviews recorded yet.</div>
                <% } else { %>
                    <table class="admin-table" style="box-shadow: none; border-radius: 0;">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Customer Info</th>
                                <th>Score</th>
                                <th>Review details</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviews.forEach(review => { %>
                                <tr>
                                    <td style="font-weight: 700; color: #111;">
                                        <%= review.product ? review.product.name : 'Unknown Product' %>
                                    </td>
                                    <td>
                                        <div style="font-weight: 600;"><%= review.customer ? review.customer.name : 'Unknown Customer' %></div>
                                        <div style="font-size: 11px; color: #666;"><%= review.customer ? review.customer.email : 'N/A' %></div>
                                    </td>
                                    <td style="color: #ff1493; font-weight: 700; font-size: 14px; white-space: nowrap;">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <%- i <= review.rating ? '★' : '☆' %>
                                        <% } %>
                                    </td>
                                    <td>
                                        <p style="font-size: 12px; color: #333; margin: 0 0 6px 0; line-height: 1.5; max-width: 350px;"><%= review.comment %></p>
                                        <span style="font-size: 10px; color: #888;">
                                            <%= new Date(review.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                        </span>
                                    </td>
                                    <td>
                                        <form action="/admin/reviews/delete/<%= review._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this review? This will also update the average product rating.')" style="margin:0;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn-submit" style="background-color: #cf222e; border-color: #cf222e; color: #fff; padding: 6px 12px; font-size: 10px;">DELETE</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>

        <!-- Right: Stats per product -->
        <div>
            <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;">RATINGS PER PRODUCT</h3>
            <div style="background: #fff; padding: 25px; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 10px 40px rgba(0,0,0,0.03); max-height: 500px; overflow-y: auto;">
                <% if (productStats.length === 0) { %>
                    <p style="color: #888; font-size: 13px; text-align: center;">No product rating breakdown available.</p>
                <% } else { %>
                    <div style="display: flex; flex-direction: column; gap: 15px;">
                        <% productStats.forEach(stat => { %>
                            <div style="border-bottom: 1px solid #f2f2f2; padding-bottom: 12px;">
                                <h4 style="font-size: 13px; font-weight: 700; color: #111; margin: 0 0 6px 0;"><%= stat._id ? stat._id.name : 'Unknown Product' %></h4>
                                <div style="display: flex; justify-content: space-between; font-size: 12px; color: #555;">
                                    <span>Rating: <strong style="color: #ff1493;"><%= stat.avgRating.toFixed(1) %> ★</strong></span>
                                    <span>Reviews: <strong><%= stat.reviewCount %></strong></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

    </div>

</body>
</html>
