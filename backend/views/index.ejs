                  <div class="category-img-wrapper">
                        <img src="/blush1.webp" alt="Face">
                    </div>
                    <p>FACE</p>
            </a>
                </div>

                <div class="category-item">
         <a href="/products?category=SKINCARE" style="text-decoration: none; color: inherit; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center;">
             <div class="category-img-wrapper">
                        <img src="/skc1.webp" alt="Skin Care">
                    </div>
