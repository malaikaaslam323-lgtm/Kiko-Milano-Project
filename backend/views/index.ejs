            <a href="/my-account" style="text-decoration: none; color: black; font-size: 12px; font-weight: 600; margin-right: 10px;">MY ACCOUNT</a>
        <% } %>
        
        <a href="/logout" style="text-decoration: none; color: black; font-size: 12px; font-weight: 600;">LOGOUT</a>
     <% } else { %>
        <a href="/login" style="text-decoration: none; color: black; display: flex; align-items: center; gap: 5px;">
            <span class="icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </span>
        </a>
     <% } %>

                <a href="/favorites" class="cart-icon-container" style="text-decoration: none; color: inherit; position: relative; display: flex; align-items: center;">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </span>
                    <span class="cart-badge fav-badge" style="background-color: #ff1493;"><%= typeof favoritesCount !== 'undefined' ? favoritesCount : 0 %></span>
                </a> 
                
                <a href="/cart" class="cart-icon-container" style="position: relative; display: flex; align-items: center; text-decoration: none; color: inherit;">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                    </span> 
                    <span class="cart-badge"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
                </a>

            </div>
        </div>

        <nav class="navbar">
            <div class="hamburger" id="hamburger">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div>
            <div class="nav-links" id="navLinks">
            <a href="/products">MAKE UP</a>
            <a href="/products?category=SKIN CARE" >SKIN CARE</a>
            <a href="/products?category=ACCESSORIES">ACCESSORIES</a>
            <a href="/products?category=FRAGRANCE">FRAGRANCES</a>
            <a href="/products?category=HAIR">HAIR</a>
            </div>
        </nav>
        
    </header>
        

   <section class="hero">
    </section>

    <section class="bestsellers">
        <h2 class="section-title">KIKO <span> MOST LOVED </span></h2>
        <div class="product-grid">
            <% bestsellers.forEach(product => { %>
                <div class="product-card" style="display: flex; flex-direction: column;">
                    <a href="/products/<%= product._id %>" style="text-decoration: none; color: inherit;">
                        <img src="/<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/Logo.webp'">
                        <h4 class="centered-text"><%= product.name %></h4>
                        <p class="price centered-text">PKR <%= product.price.toLocaleString() %></p>
                        <div class="kiko-rating" style="display: flex; align-items: center; justify-content: center; gap: 5px; margin-bottom: 12px; font-size: 11px;">
                            <% if (product.reviewsCount && product.reviewsCount > 0) { %>
                                <span style="color: #ff1493; font-weight: 700;"><%= product.rating.toFixed(1) %>/5</span>
                                <span style="color: #ff1493;">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <%= i <= Math.round(product.rating) ? '★' : '☆' %>
                                    <% } %>
                                </span>
                                <span>(<%= product.reviewsCount %>)</span>
                            <% } else { %>
                                <span style="color: #888;">No Reviews Yet</span>
                            <% } %>
                        </div>
                    </a>
                    <div class="card-action" style="margin-top: auto; justify-content: center; gap: 15px;">
                        <form action="/cart/add" method="POST" class="ajax-cart-form" style="margin: 0; display: inline;">
                            <input type="hidden" name="productId" value="<%= product._id %>">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="btn-secondary" style="border-radius: 7px; padding: 12px 25px; font-weight: bold; cursor: pointer; float: none; width: auto; margin: 0;">ADD TO BAG</button>
                        </form>
                        <div class="like">
                            <span class="like-icon <%= typeof favoritesList !== 'undefined' && favoritesList.includes(product._id.toString()) ? 'liked' : '' %>" data-product-id="<%= product._id %>"><%- typeof favoritesList !== 'undefined' && favoritesList.includes(product._id.toString()) ? '&#9829;' : '&#9825;' %></span>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div> <a href="/products" class="view-all-btn" style="text-decoration: none; display: inline-block; text-align: center;">VIEW ALL</a>
        
    </section>
<section class="top-categories">
