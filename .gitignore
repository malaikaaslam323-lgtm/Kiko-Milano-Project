# Node modules (ignored because they are re-downloaded via npm install)
node_modules/
**/node_modules/

# Local environment variables (keeps database passwords and secret keys private)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/ .env

# Frontend build outputs (ignored because hosts like Vercel build this dynamically)
dist/
dist-ssr/
*.local
build/

# Editor config files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
